# ════════════════════════════════════════════════════════════════════════════════
# ARCHIVO DE CONFIGURACIÓN DEL SISTEMA DE COTIZACIONES
# Copia este archivo como ".env" y llena los valores antes de arrancar.
# NUNCA subas el archivo .env real a un repositorio git.
# ════════════════════════════════════════════════════════════════════════════════

# ── Información general ────────────────────────────────────────────────────────
APP_NOMBRE=Cotizador IA
APP_VERSION=1.0.0

# ── Base de datos SQLite ───────────────────────────────────────────────────────
# Se crea automáticamente. No necesitas instalar nada.
DATABASE_URL=sqlite+aiosqlite:///./cotizador.db

# ── Excel de lista de precios ──────────────────────────────────────────────────
# INSTRUCCIÓN PRINCIPAL: Pon aquí la ruta a tu archivo Excel de precios.
#
# Ejemplos válidos en Windows:
#   EXCEL_RUTA=C:\Users\Juan\Documentos\lista_precios.xlsx
#   EXCEL_RUTA=..\listas\precios_2024.xlsx
#   EXCEL_RUTA=./lista_precios.xlsx
#
# IMPORTANTE: Usa barras normales (/) o doble barra inversa (\\) en Windows.
# Ruta con espacios debe ir entre comillas: EXCEL_RUTA="C:\Mi Carpeta\precios.xlsx"
EXCEL_RUTA=./lista_precios.xlsx

# Nombre de la hoja del Excel (déjalo vacío para usar la primera hoja)
EXCEL_HOJA=

# Fila del encabezado (0 = primera fila). Cambia si el Excel tiene filas antes del encabezado.
EXCEL_FILA_ENCABEZADO=0

# ── Groq API ───────────────────────────────────────────────────────────────────
# Obtén tu API key gratuita en: https://console.groq.com
# La clave empieza con "gsk_"
GROQ_API_KEY=tu_api_key_de_groq_aqui

# Modelo a usar. Opciones recomendadas:
#   llama-3.3-70b-versatile   ← recomendado, mejor calidad
#   llama-3.1-8b-instant      ← más rápido, menor calidad
#   mixtral-8x7b-32768        ← alternativa
GROQ_MODELO=llama-3.3-70b-versatile

# Temperatura del LLM (0.0 = más determinista, 1.0 = más creativo)
# Para extracción de productos, 0.0 - 0.2 es lo ideal
GROQ_TEMPERATURA=0.1

# Máximo de tokens en la respuesta
GROQ_MAX_TOKENS=2000

# ── Umbrales de matching ───────────────────────────────────────────────────────
# Score >= UMBRAL_ALTO: coincidencia automática (sin advertencia)
# Score entre UMBRAL_BAJO y UMBRAL_ALTO: coincidencia dudosa (con advertencia)
# Score < UMBRAL_BAJO: producto no encontrado (cotización manual)
#
# Valores son porcentajes (0-100).
# Si hay demasiados falsos positivos, sube MATCHING_UMBRAL_ALTO a 80 o 85.
# Si el sistema no encuentra productos obvios, baja MATCHING_UMBRAL_BAJO a 40.
MATCHING_UMBRAL_ALTO=75.0
MATCHING_UMBRAL_BAJO=50.0
MATCHING_MAX_CANDIDATOS=5

# ── CORS ───────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma. Incluye el puerto del frontend.
# No cambies esto salvo que muevas el frontend a otro puerto.

# ── Exportación ────────────────────────────────────────────────────────────────
# Carpeta donde se guardan los Excel generados (se crea automáticamente)
EXPORTAR_DIR_TEMPORAL=./temp_cotizaciones
EXPORTAR_NOMBRE_BASE=cotizacion
